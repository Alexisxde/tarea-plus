---
import '@fontsource/poppins'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html class="dark" lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/tarealogo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Aplicación de gestión de tareas que te ayuda a organizar tu vida."
    />
    <meta property="og:image" content="https://tareaplus.vercel.app/tarealogo.png" />
    <meta property="og:url" content="https://tareaplus.vercel.app" />
    <meta property="og:site__name" content="Tarea+" />
  </head>
  <body
    class="mx-auto max-w-[1366px] bg-neutral-50 text-neutral-900 transition-colors duration-300 dark:bg-neutral-900 dark:text-neutral-50">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    font-family: 'Poppins';
  }
</style>
